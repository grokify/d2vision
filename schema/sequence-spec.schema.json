{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/grokify/d2vision/generate/sequence-spec",
  "$ref": "#/$defs/SequenceSpec",
  "$defs": {
    "ActorSpec": {
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "shape": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id"
      ]
    },
    "GroupSpec": {
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "messages": {
          "items": {
            "$ref": "#/$defs/MessageSpec"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "messages"
      ]
    },
    "MessageSpec": {
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "from",
        "to"
      ]
    },
    "SequenceSpec": {
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "actors": {
          "items": {
            "$ref": "#/$defs/ActorSpec"
          },
          "type": "array"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/MessageSpec"
          },
          "type": "array"
        },
        "groups": {
          "items": {
            "$ref": "#/$defs/GroupSpec"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object",
      "required": [
        "id",
        "steps"
      ]
    }
  },
  "title": "SequenceSpec",
  "description": "Defines a sequence diagram with actors and message steps."
}